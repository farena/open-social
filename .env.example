# Open Social environment variables.
# Copy to .env.local and fill in as needed. All keys are optional —
# the app boots with sensible defaults when they are unset.

# Absolute path to the Claude CLI binary. Leave empty to auto-discover
# via PATH and the standard install locations (see src/lib/claude-path.ts).
CLAUDE_CLI_PATH=

# Override the SQLite database path. Defaults to data/sales.db relative
# to the working directory. Useful for splitting dev / staging stores.
DB_PATH=

# SQLite database path used when running under vitest. Tests will refuse
# to start if neither this nor the per-test override is set — this is
# the safety net that prevents test fixtures from hitting the real DB.
# Leave empty to use a per-worker temp file (see tests/setup-db.ts).
TEST_DB_PATH=

# Set to any non-empty value to skip auto-launching the dev server when
# `npm run setup` finishes. Useful for CI / headless setups.
OC_SETUP_NO_DEV=
